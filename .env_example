# Parameters from this API server
################################
# Token to auth this API
OTOBO_AI_API_KEY=<use a secret API key>

# Optional, Ip address of this server inside the docker, default is "0.0.0.0"
OTOBO_AI_HOST=0.0.0.0

# Optional: port of this server
OTOBO_AI_PORT=8000


# Parameters for Vector Database
###############################
OTOBO_AI_CHROMA_DIR=/chroma


# Parameters for language models
#####################
# Optional: token to auth the llm server
OTOBO_AI_LLM_API_KEY="secret-to-use-otobo-ai-server"

# Optional: URL llama server, default is "http://localhost:11434" (can change in future)
OTOBO_AI_LLM_HOST=http://localhost:11434

# Optional: llama llm model, default is llama2:13b-chat
OTOBO_AI_LLM_MODEL=llama3.3:70b

# Optional: embedding model, default is bge-m3
### WARNING ###
# Changeing this value in production will require to recreate the database because the dimension of the embedding models might be different.
# OTOBO_AI_EMBEDDING_MODEL=bge-m3

# Optional: temperature (see llama doc), default is 0.1
# OTOBO_AI_LLM_TEMPERATURE=0.1

# Parameters for LANGFUSE
# Optional: Keys for debugging
#####################
# OTOBO_AI_LANGFUSE_PK
# OTOBO_AI_LANGFUSE_SK
# OTOBO_AI_LANGFUSE_HOST

# OTOBO_AI_LOG_FILE
# OTOBO_AI_LOG_LEVEL

# Parameters for PostgreSQL
#####################
OTOBO_AI_PG_HOST=postgres
OTOBO_AI_PG_PORT=5432
OTOBO_AI_PG_DB=fulltext
OTOBO_AI_PG_USER=otobo_ai
OTOBO_AI_PG_PW=your password
